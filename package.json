{
  "name": "healthy-turtle",
  "version": "2.0.0-alpha.0",
  "description": "A privacy-first Chrome extension that highlights food-label information based on dietary preferences.",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "build": "npm run typecheck && vite build",
    "dev": "vite build --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RipplyPear/HealthyTurtle.git"
  },
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "nutrition",
    "food-labels",
    "typescript"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
