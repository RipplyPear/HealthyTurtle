{
  "manifest_version": 3,
  "name": "HealthyTurtle",
  "version": "2.0.0",
  "description": "Highlights food-label information based on dietary preferences.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "HealthyTurtle",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.freshful.ro/*"
      ],
      "js": [
        "content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
